# ── Node / Evidence.dev ──────────────────────────────────────────────────────
# Ignore dashboard dependencies, generated templates, and build outputs.
# These can each be 1+ GB; never commit them.
dashboard/node_modules/
dashboard/.evidence/
dashboard/.svelte-kit/
dashboard/build/
.npm/

# PROTECTED — do NOT ignore the static asset directory or the generated route
# map. SvelteKit's production build expects `dashboard/static/` to be writable
# and to contain `routes_map.html` at build time (the GitHub Actions workflow
# regenerates it from MotherDuck-derived parquet files before `npm run build`).
# The `!` allowlist below defends against any future wildcard rule that might
# accidentally match these paths.
!dashboard/static/
!dashboard/static/**
!dashboard/static/routes_map.html

